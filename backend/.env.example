# Environment variables for database configuration

# Database type: 'sqlite' for development, 'postgresql' for production
DATABASE_TYPE=sqlite

# PostgreSQL settings (only used when DATABASE_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beauty_crm
POSTGRES_USER=beauty_crm_user
POSTGRES_PASSWORD=your_secure_password_here

# SQLite settings (only used when DATABASE_TYPE=sqlite)
SQLITE_DB_PATH=./beauty_crm.db
