# ==============================================
# НАСТРОЙКИ ИНТЕГРАЦИЙ ДЛЯ BEAUTY CRM
# ==============================================

# ========== EMAIL (SMTP) ==========
# Настройки для отправки документов по email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Beauty CRM

# ========== TELEGRAM BOT ==========
# Токен бота для отправки документов
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ========== WHATSAPP BUSINESS API ==========
# Настройки WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ========== ПЛАТЕЖНЫЕ СИСТЕМЫ ==========

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Yookassa (ЮKassa)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Tinkoff
TINKOFF_TERMINAL_KEY=your-terminal-key
TINKOFF_SECRET_KEY=your-secret-key

# Сбербанк
SBERBANK_USERNAME=your-username
SBERBANK_PASSWORD=your-password

# Альфа-Банк
ALFABANK_LOGIN=your-login
ALFABANK_PASSWORD=your-password

# Kaspi.kz
KASPI_MERCHANT_ID=your-merchant-id
KASPI_API_KEY=your-api-key

# Halyk Bank
HALYK_MERCHANT_ID=your-merchant-id
HALYK_SECRET_KEY=your-secret-key

# Freedom Finance
FREEDOM_API_KEY=your-api-key
FREEDOM_SECRET=your-secret

# Emirates NBD
EMIRATES_NBD_MERCHANT_ID=your-merchant-id
EMIRATES_NBD_API_KEY=your-api-key

# ADCB
ADCB_MERCHANT_ID=your-merchant-id
ADCB_SECRET_KEY=your-secret-key

# Mashreq Bank
MASHREQ_MERCHANT_ID=your-merchant-id
MASHREQ_API_KEY=your-api-key

# PayPal
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
PAYPAL_MODE=sandbox  # или production

# ========== МАРКЕТПЛЕЙСЫ ==========

# Яндекс.Карты
YANDEX_MAPS_API_KEY=your-api-key
YANDEX_MAPS_ORG_ID=your-organization-id

# 2GIS
TWOGIS_API_KEY=your-api-key
TWOGIS_FIRM_ID=your-firm-id

# Google Business
GOOGLE_BUSINESS_API_KEY=your-api-key
GOOGLE_BUSINESS_LOCATION_ID=your-location-id

# Booksy
BOOKSY_API_KEY=your-api-key
BOOKSY_BUSINESS_ID=your-business-id

# YCLIENTS
YCLIENTS_LOGIN=your-login
YCLIENTS_PASSWORD=your-password
YCLIENTS_COMPANY_ID=your-company-id

# Wildberries
WILDBERRIES_API_KEY=your-api-key
WILDBERRIES_SUPPLIER_ID=your-supplier-id

# Ozon
OZON_CLIENT_ID=your-client-id
OZON_API_KEY=your-api-key

# Amazon
AMAZON_ACCESS_KEY=your-access-key
AMAZON_SECRET_KEY=your-secret-key
AMAZON_SELLER_ID=your-seller-id
AMAZON_MARKETPLACE_ID=your-marketplace-id

# ========== ОБЩИЕ НАСТРОЙКИ ==========
ENVIRONMENT=development  # development или production
PDF_OUTPUT_DIR=/tmp/crm_pdfs
DOCUMENT_STORAGE_DIR=/var/www/crm/documents

# ========== БАЗА ДАННЫХ ==========
# (Уже должно быть настроено)
DATABASE_URL=postgresql://user:password@localhost:5432/beauty_crm
